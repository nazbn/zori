ZOTERO_API_KEY=your_zotero_api_key
ZOTERO_LIBRARY_ID=your_library_id   # optional — can also be set in config.yaml

OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# LangSmith tracing (optional) — https://smith.langchain.com
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=zori

# Structured JSON log directory (optional) — timestamped files written only when --debug is active
# LOG_DIR=.zori/logs
