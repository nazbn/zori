# LLM Backend
llm:
  provider: openai          # openai | anthropic | ollama
  model: gpt-4o             # or claude-sonnet-4-6 | or llama3.2 (ollama)
  temperature: 0.2

# Embeddings
embeddings:
  provider: openai          # openai | huggingface | ollama
  model: text-embedding-3-small  # or nomic-embed-text (ollama)

# Vector Store
vector_store:
  provider: chroma          # chroma | qdrant
  persist_directory: .zori/chroma
  # qdrant_url: http://localhost:6333  # if using Qdrant

# Ingestion
ingestion:
  mode: batch               # batch | on_demand | hybrid
  sync_on_startup: true     # check Zotero for new items on launch
  chunk_size: 1000
  chunk_overlap: 200

# Zotero
zotero:
  library_id: YOUR_LIBRARY_ID
  library_type: user        # user | group
  # api_key loaded from .env

# Search
search:
  # Maximum number of search refinement rounds paper_finder can run
  # before returning its best results. 1 = no follow-up searches.
  max_search_iterations: 3
